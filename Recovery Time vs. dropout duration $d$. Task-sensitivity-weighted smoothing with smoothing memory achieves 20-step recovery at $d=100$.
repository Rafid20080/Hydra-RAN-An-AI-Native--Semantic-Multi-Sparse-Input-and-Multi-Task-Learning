class DynamicRecoveryGenerator:
    """
    Generates recovery time data dynamically based on configuration
    Results change based on dataset complexity and model parameters
    """
    
    def __init__(self, dataset_config: DatasetConfig, model_config: ModelConfig, 
                 sim_config: SimulationConfig):
        self.dataset_config = dataset_config
        self.model_config = model_config
        self.sim_config = sim_config
        np.random.seed(sim_config.seed)
        
    def _get_complexity_factor(self) -> float:
        """Get factor based on dataset complexity"""
        factors = {
            "simple": 0.5,
            "moderate": 1.0,
            "complex": 1.5,
            "realistic": 1.2,
            "challenging": 2.0
        }
        return factors.get(self.dataset_config.complexity, 1.0)
    
    def _get_noise_impact(self, duration: int) -> float:
        """Calculate noise impact based on dataset configuration"""
        base_noise = self.dataset_config.noise_level
        snr_factor = 10 ** (-self.dataset_config.signal_to_noise_ratio / 20)
        sparsity_factor = 1 + self.dataset_config.sparsity * 2
        outlier_factor = 1 + self.dataset_config.outlier_ratio * 5
        
        return base_noise * snr_factor * sparsity_factor * outlier_factor * (1 + np.log1p(duration) / 100)
    
    def _get_model_recovery_multiplier(self) -> float:
        """Get recovery speed multiplier based on model configuration"""
        multipliers = {
            "task_weighted_memory": 0.6,
            "task_weighted_only": 0.8,
            "standard_ema": 1.0,
            "adaptive": 0.7,
            "predictive": 0.5
        }
        base = multipliers.get(self.model_config.recovery_strategy, 1.0)
        
        # Adjust for network type
        network_multipliers = {
            "semantic_smtl": 1.0,
            "jcas": 1.4,
            "graph_ran": 1.3,
            "drl_only": 1.8,
            "hybrid": 0.9
        }
        network_factor = network_multipliers.get(self.model_config.network_type, 1.0)
        
        # Adjust for adaptive beta
        if self.model_config.adaptive_beta:
            base *= 0.85
        
        return base * network_factor
    
    def _calculate_theoretical_recovery(self, duration: int) -> float:
        """Calculate theoretical recovery time based on Theorem 4"""
        beta = self.model_config.beta
        initial_error = 0.5
        epsilon = 0.05
        
        # Theoretical bound: T_rec ≤ (1/β) log(||error||²/ε)
        theory_bound = (1 / beta) * np.log(initial_error**2 / epsilon)
        
        # Adjust for duration
        duration_factor = np.sqrt(duration / 100) if duration > 0 else 1
        
        return theory_bound * duration_factor
    
    def generate_recovery_data_for_method(self, method_name: str, 
                                         dropout_durations: np.ndarray) -> Tuple[np.ndarray, np.ndarray]:
        """
        Generate recovery time data for a specific method
        Dynamic based on configuration
        """
        complexity_factor = self._get_complexity_factor()
        noise_impact = self._get_noise_impact(1)
        model_multiplier = self._get_model_recovery_multiplier()
        
        # Base recovery parameters for different methods
        method_params = {
            "task_weighted_memory": {
                "base_recovery": 5,
                "growth_rate": 0.12,
                "std_base": 1.0,
                "std_growth": 0.015,
                "max_recovery": 80
            },
            "task_weighted_only": {
                "base_recovery": 6,
                "growth_rate": 0.18,
                "std_base": 1.2,
                "std_growth": 0.02,
                "max_recovery": 110
            },
            "standard_ema": {
                "base_recovery": 8,
                "growth_rate": 0.28,
                "std_base": 1.5,
                "std_growth": 0.025,
                "max_recovery": 180
            },
            "jcas": {
                "base_recovery": 15,
                "growth_rate": 0.35,
                "std_base": 2.5,
                "std_growth": 0.03,
                "max_recovery": 280
            },
            "graph_ran": {
                "base_recovery": 12,
                "growth_rate": 0.32,
                "std_base": 2.0,
                "std_growth": 0.028,
                "max_recovery": 230
            },
            "drl_only": {
                "base_recovery": 25,
                "growth_rate": 0.55,
                "std_base": 4.0,
                "std_growth": 0.045,
                "max_recovery": 500
            }
        }
        
        params = method_params.get(method_name, method_params["standard_ema"])
        
        # Apply dynamic adjustments
        adjusted_base = params["base_recovery"] * complexity_factor * model_multiplier
        adjusted_growth = params["growth_rate"] * complexity_factor * (1 + noise_impact * 0.1)
        adjusted_std_base = params["std_base"] * (1 + noise_impact * 0.2)
        adjusted_std_growth = params["std_growth"] * (1 + noise_impact * 0.15)
        
        # Generate mean recovery times
        mean_recovery = adjusted_base + adjusted_growth * dropout_durations
        
        # Apply non-linear scaling for large durations
        mean_recovery = mean_recovery * (1 + 0.05 * np.log1p(dropout_durations / 100))
        
        # Add dataset-specific effects
        if self.dataset_config.temporal_coherence < 0.5:
            mean_recovery *= 1.2
        
        if self.dataset_config.task_correlation < 0.5:
            mean_recovery *= 1.15
        
        # Apply maximum constraint
        mean_recovery = np.minimum(mean_recovery, params["max_recovery"] * complexity_factor)
        
        # Generate standard deviations
        std_recovery = adjusted_std_base + adjusted_std_growth * dropout_durations
        std_recovery = std_recovery * (1 + noise_impact * 0.3)
        
        # Add random variation based on configuration
        if self.dataset_config.outlier_ratio > 0:
            outlier_mask = np.random.random(len(dropout_durations)) < self.dataset_config.outlier_ratio
            mean_recovery[outlier_mask] *= np.random.uniform(1.2, 1.8, np.sum(outlier_mask))
        
        if self.dataset_config.missing_data_ratio > 0:
            missing_mask = np.random.random(len(dropout_durations)) < self.dataset_config.missing_data_ratio
            std_recovery[missing_mask] *= np.random.uniform(1.3, 2.0, np.sum(missing_mask))
        
        return mean_recovery, std_recovery
    
    def generate_all_recovery_data(self) -> Dict:
        """Generate recovery data for all methods"""
        dropout_durations = np.array(self.sim_config.dropout_durations)
        
        methods = [
            "task_weighted_memory",
            "task_weighted_only", 
            "standard_ema",
            "jcas",
            "graph_ran",
            "drl_only"
        ]
        
        data = {'d': dropout_durations}
        
        for method in methods:
            mean, std = self.generate_recovery_data_for_method(method, dropout_durations)
            data[method] = {'mean': mean, 'std': std}
        
        return data

