def run_dynamic_simulation(preset: str = "standard",
                          custom_config: Optional[Dict] = None,
                          save_prefix: str = "recovery_time_dynamic"):
    """
    Run dynamic simulation with specified configuration
    
    Parameters:
    -----------
    preset : str
        Preset configuration name
    custom_config : dict, optional
        Custom configuration overrides
    save_prefix : str
        Prefix for saved files
    """
    
    # Get preset configuration
    dataset_config, model_config, sim_config, viz_config = get_preset_config(preset)
    
    # Apply custom overrides
    if custom_config:
        if 'dataset' in custom_config:
            for key, value in custom_config['dataset'].items():
                if hasattr(dataset_config, key):
                    setattr(dataset_config, key, value)
        if 'model' in custom_config:
            for key, value in custom_config['model'].items():
                if hasattr(model_config, key):
                    setattr(model_config, key, value)
        if 'simulation' in custom_config:
            for key, value in custom_config['simulation'].items():
                if hasattr(sim_config, key):
                    setattr(sim_config, key, value)
    
    print("\n" + "=" * 70)
    print(f"DYNAMIC RECOVERY TIME SIMULATION")
    print(f"Preset: {preset.upper()}")
    print("=" * 70)
    print(f"Dataset Complexity: {dataset_config.complexity}")
    print(f"Noise Level: {dataset_config.noise_level}")
    print(f"Sparsity: {dataset_config.sparsity}")
    print(f"Network Type: {model_config.network_type}")
    print(f"Recovery Strategy: {model_config.recovery_strategy}")
    print(f"Beta: {model_config.beta}")
    print("=" * 70)
    
    # Generate dynamic data
    generator = DynamicRecoveryGenerator(dataset_config, model_config, sim_config)
    data = generator.generate_all_recovery_data()
    
    # Create plotter and generate figure
    plotter = DynamicPlotter(viz_config)
    fig = plotter.plot_recovery_time(data, dataset_config, model_config, save_prefix)
    
    # Print summary
    print_summary(data, dataset_config, model_config)
    
    return fig, data

def print_summary(data: Dict, dataset_config: DatasetConfig, model_config: ModelConfig):
    """Print comprehensive summary of results"""
    
    print("\n" + "=" * 70)
    print("DYNAMIC SIMULATION SUMMARY")
    print("=" * 70)
    
    # Find index for d=100
    d = data['d']
    idx_100 = np.where(d == 100)[0]
    
    if len(idx_100) > 0:
        idx = idx_100[0]
        recovery_proposed = data['task_weighted_memory']['mean'][idx]
        recovery_ema = data['standard_ema']['mean'][idx]
        recovery_drl = data['drl_only']['mean'][idx]
        
        print(f"\nKEY RESULT (d = 100 steps):")
        print(f"Recovery time: {int(recovery_proposed)} steps")
        
        print(f"\nPERFORMANCE COMPARISON:")
        methods = ['task_weighted_memory', 'task_weighted_only', 'standard_ema', 'jcas', 'graph_ran', 'drl_only']
