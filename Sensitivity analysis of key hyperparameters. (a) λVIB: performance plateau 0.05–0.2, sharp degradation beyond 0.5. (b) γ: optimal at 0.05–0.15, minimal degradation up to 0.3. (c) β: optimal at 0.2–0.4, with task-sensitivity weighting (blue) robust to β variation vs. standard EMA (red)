# =============================================================================

def run_simulation(config: Optional[Union[SimulationConfig, Dict, str]] = None,
                  save_prefix: str = 'figure_sensitivity_analysis') -> Dict:
    """
    Run the dynamic simulation
    
    Parameters:
    -----------
    config : SimulationConfig, dict, or str
        Configuration for the simulation. Can be:
        - SimulationConfig object
        - Dictionary with configuration parameters
        - Path to JSON configuration file
    save_prefix : str
        Prefix for saved figure files
    
    Returns:
    --------
    Dict containing statistical results
    """
    
    # Initialize configuration
    if config is None:
        config = SimulationConfig()
    elif isinstance(config, dict):
        config = SimulationConfig(**config)
    elif isinstance(config, str):
        config = SimulationConfig(config_file=config)
    
    # Initialize data generator and plotter
    data_generator = DynamicDataGenerator(config)
    plotter = DynamicPlotter(config)
    
    print("=" * 80)
    print("DYNAMIC IEEE TCCN SIMULATION")
    print(f"Dataset Type: {config.dataset.name}")
    print(f"Task Correlation: {config.dataset.task_correlation}")
    print(f"Data Quality Factor: {config.dataset.data_quality_factor}")
    print(f"Model Sensitivity: {config.model.sensitivity_to_lambda}")
    print("=" * 80)
    
    # Generate plots
    fig = plotter.plot_sensitivity_analysis(data_generator)
    
    # Save figures
    fig.savefig(f'{save_prefix}.pdf', format='pdf', dpi=config.visualization.dpi, 
                bbox_inches='tight')
    fig.savefig(f'{save_prefix}.png', format='png', dpi=config.visualization.dpi,
                bbox_inches='tight', facecolor='white')
    
    print(f"\n✓ Figures saved:")
    print(f"  - {save_prefix}.pdf")
    print(f"  - {save_prefix}.png")
    
    # Generate statistics
    results = generate_statistical_summary(data_generator, config)
    
    plt.show()
    
    return results

