def generate_statistical_summary(data_generator: DynamicDataGenerator, 
                                 config: SimulationConfig) -> Dict:
    """Generate statistical summary with dynamic analysis"""
    
    print("\n" + "=" * 80)
    print(f"DYNAMIC STATISTICAL SUMMARY")
    print(f"Dataset: {config.dataset.name}")
    print(f"Model Sensitivity: λ={config.model.sensitivity_to_lambda}")
    print("=" * 80)
    
    results = {}
    
    # Lambda analysis
    lambda_vals, tsr_lambda, _ = data_generator.generate_lambda_vib_data()
    
    optimal_idx = np.argmax(tsr_lambda)
    optimal_lambda = lambda_vals[optimal_idx]
    
    results['optimal_lambda'] = optimal_lambda
    results['max_performance'] = tsr_lambda[optimal_idx]
    
    print("\nλ_VIB ANALYSIS")
    print("-" * 40)
    print(f"Optimal λ value: {optimal_lambda:.4f}")
    print(f"Peak performance: {tsr_lambda[optimal_idx]:.2f}%")
    print(f"Mean performance: {np.mean(tsr_lambda):.2f}% ± {np.std(tsr_lambda):.2f}%")
    
    # Gamma analysis
    gamma_vals, tsr_gamma, _ = data_generator.generate_gamma_data()
    
    optimal_gamma_idx = np.argmax(tsr_gamma)
    optimal_gamma = gamma_vals[optimal_gamma_idx]
    
    results['optimal_gamma'] = optimal_gamma
    results['gamma_peak'] = tsr_gamma[optimal_gamma_idx]
    
    print("\nγ ANALYSIS")
    print("-" * 40)
    print(f"Optimal γ value: {optimal_gamma:.4f}")
    print(f"Peak performance: {tsr_gamma[optimal_gamma_idx]:.2f}%")
    
    # Beta analysis - proposed vs EMA
    beta_vals, tsr_proposed, tsr_ema, _, _ = data_generator.generate_beta_data()
    
    improvement = np.mean(tsr_proposed) - np.mean(tsr_ema)
    relative_improvement = (improvement / np.mean(tsr_ema)) * 100
    
    results['proposed_mean'] = np.mean(tsr_proposed)
    results['ema_mean'] = np.mean(tsr_ema)
    results['improvement'] = improvement
    
    print("\nβ ANALYSIS (Proposed vs EMA)")
    print("-" * 40)
    print(f"Proposed method: {np.mean(tsr_proposed):.2f}% ± {np.std(tsr_proposed):.2f}%")
    print(f"Standard EMA: {np.mean(tsr_ema):.2f}% ± {np.std(tsr_ema):.2f}%")
    print(f"Improvement: {improvement:+.2f}% ({relative_improvement:+.1f}%)")
    
    # Statistical significance test
    t_stat, p_value = stats.ttest_ind(tsr_proposed, tsr_ema)
    results['p_value'] = p_value
    results['t_statistic'] = t_stat
    
    print(f"\nStatistical significance: t={t_stat:.3f}, p={p_value:.5f}")
    
    return results

