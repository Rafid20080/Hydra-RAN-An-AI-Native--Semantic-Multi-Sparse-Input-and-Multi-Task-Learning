# =============================================================================
# ENUMS AND DATA CLASSES
# =============================================================================

class DatasetType(Enum):
    """Supported dataset types with different characteristics"""
    STANDARD = "standard"
    EASY = "easy"          # Higher performance, more robust
    DIFFICULT = "difficult" # Lower performance, more sensitive
    NOISY = "noisy"        # High noise levels
    SPARSE = "sparse"      # Limited data points
    IMBALANCED = "imbalanced" # Uneven performance across parameters

class ScenarioType(Enum):
    """Different experimental scenarios"""
    DEFAULT = "default"
    HIGH_CORRELATION = "high_correlation"
    LOW_CORRELATION = "low_correlation"
    REAL_WORLD = "real_world"
    SYNTHETIC = "synthetic"

@dataclass
class DatasetConfig:
    """Configuration for dataset characteristics"""
    name: str = "standard"
    noise_seed: int = 42
    data_quality_factor: float = 1.0
    sample_size: int = 100
    outlier_ratio: float = 0.0
    missing_data_ratio: float = 0.0
    task_correlation: float = 0.7
    base_performance: float = 93.5
    
@dataclass
class ModelConfig:
    """Configuration for model behavior"""
    sensitivity_to_lambda: float = 1.0
    sensitivity_to_gamma: float = 1.0
    sensitivity_to_beta: float = 1.0
    noise_level: float = 0.3
    optimization_level: str = "standard"  # low, standard, high
    regularization_strength: float = 0.1

@dataclass
class VisualizationConfig:
    """Configuration for plots"""
    figure_width: float = 7.7
    figure_height: float = 4.1
    dpi: int = 300
    annotation_enabled: bool = True
    grid_enabled: bool = True
    error_bars_enabled: bool = True
    show_statistics: bool = True

@dataclass
class HyperparameterConfig:
    """Configuration for hyperparameter ranges"""
    lambda_min: float = 0.0
    lambda_max: float = 1.0
    lambda_points: int = 17
    gamma_min: float = 0.0
    gamma_max: float = 1.0
    gamma_points: int = 17
    beta_min: float = 0.01
    beta_max: float = 0.8
    beta_points: int = 25

class SimulationConfig:
    """Main configuration class"""
    def __init__(self, config_file: Optional[str] = None, **kwargs):
        self.dataset = DatasetConfig()
        self.model = ModelConfig()
        visualization = VisualizationConfig()
        self.hyperparameters = HyperparameterConfig()
        
        if config_file and os.path.exists(config_file):
            self.load_from_file(config_file)
        
        # Apply keyword arguments
        for key, value in kwargs.items():
            if hasattr(self, key):
                if isinstance(getattr(self, key), (DatasetConfig, ModelConfig, VisualizationConfig, HyperparameterConfig)):
                    for subkey, subvalue in value.items():
                        if hasattr(getattr(self, key), subkey):
                            setattr(getattr(self, key), subkey, subvalue)
                else:
                    setattr(self, key, value)
    
    def load_from_file(self, config_file: str):
        """Load configuration from JSON file"""
        with open(config_file, 'r') as f:
            data = json.load(f)
        
        if 'dataset' in data:
            for key, value in data['dataset'].items():
                if hasattr(self.dataset, key):
                    setattr(self.dataset, key, value)
        
        if 'model' in data:
            for key, value in data['model'].items():
                if hasattr(self.model, key):
                    setattr(self.model, key, value)
        
        if 'hyperparameters' in data:
            for key, value in data['hyperparameters'].items():
                if hasattr(self.hyperparameters, key):
                    setattr(self.hyperparameters, key, value)
    
    def to_dict(self) -> Dict:
        """Convert configuration to dictionary"""
        return {
            'dataset': asdict(self.dataset),
            'model': asdict(self.model),
            'hyperparameters': asdict(self.hyperparameters)
        }

# =============================================================================
# DYNAMIC DATA GENERATOR
# =============================================================================

class DynamicDataGenerator:
    """Generates data dynamically based on configuration"""
    
    def __init__(self, config: SimulationConfig):
        self.config = config
        self._setup_random_seeds()
        self._cache = {}
    
    def _setup_random_seeds(self):
        """Setup random seeds for reproducibility"""
        np.random.seed(self.config.dataset.noise_seed)
    
    def _apply_data_quality(self, data: np.ndarray) -> np.ndarray:
        """Apply data quality transformations"""
        quality_factor = self.config.dataset.data_quality_factor
        outlier_ratio = self.config.dataset.outlier_ratio
        missing_ratio = self.config.dataset.missing_data_ratio
        
        # Apply quality factor
        if quality_factor < 1.0:
            noise = np.random.normal(0, 1 - quality_factor, len(data))
            data = data + noise * data * 0.1
        
        # Add outliers
        if outlier_ratio > 0:
            n_outliers = int(len(data) * outlier_ratio)
            outlier_indices = np.random.choice(len(data), n_outliers, replace=False)
            outlier_magnitude = np.random.uniform(1.5, 3.0, n_outliers)
            data[outlier_indices] = data[outlier_indices] * outlier_magnitude
            data = np.clip(data, 0, 100)
        
        # Add missing data (set to NaN)
        if missing_ratio > 0:
            n_missing = int(len(data) * missing_ratio)
            missing_indices = np.random.choice(len(data), n_missing, replace=False)
            data[missing_indices] = np.nan
        
        # Interpolate missing values
        if missing_ratio > 0:
            mask = ~np.isnan(data)
            if np.sum(mask) > 1:
                data = np.interp(np.arange(len(data)), 
                                np.where(mask)[0], 
                                data[mask])
        
        return data
    
    def _get_performance_multiplier(self) -> float:
        """Get performance multiplier based on dataset type"""
        multipliers = {
            DatasetType.STANDARD.value: 1.0,
            DatasetType.EASY.value: 1.08,
            DatasetType.DIFFICULT.value: 0.85,
            DatasetType.NOISY.value: 0.92,
            DatasetType.SPARSE.value: 0.88,
            DatasetType.IMBALANCED.value: 0.90
        }
        return multipliers.get(self.config.dataset.name, 1.0)
    
    def _get_sensitivity_multiplier(self) -> float:
        """Get sensitivity multiplier based on dataset type"""
        multipliers = {
            DatasetType.STANDARD.value: 1.0,
            DatasetType.EASY.value: 0.6,
            DatasetType.DIFFICULT.value: 1.8,
            DatasetType.NOISY.value: 1.3,
            DatasetType.SPARSE.value: 1.2,
            DatasetType.IMBALANCED.value: 1.4
        }
        return multipliers.get(self.config.dataset.name, 1.0)
    
    def generate_lambda_vib_data(self) -> Tuple[np.ndarray, np.ndarray, np.ndarray]:
        """Generate lambda VIB data with dynamic behavior"""
        
        lambda_min = self.config.hyperparameters.lambda_min
        lambda_max = self.config.hyperparameters.lambda_max
        lambda_points = self.config.hyperparameters.lambda_points
        
        lambda_vals = np.linspace(lambda_min, lambda_max, lambda_points)
        
        perf_mult = self._get_performance_multiplier()
        sens_mult = self._get_sensitivity_multiplier()
        base_perf = self.config.dataset.base_performance * perf_mult
        model_sens = self.config.model.sensitivity_to_lambda * sens_mult
        
        dataset_type = self.config.dataset.name
        
        # Different performance curves for different dataset types
        if dataset_type == DatasetType.EASY.value:
            # Easy dataset: robust, high plateau
            tsr_mean = base_perf - 12 * (lambda_vals - 0.12)**2 * model_sens
            tsr_mean = np.clip(tsr_mean, 80, base_perf + 2)
            std_lambda = 1.2 + 0.4 * (lambda_vals - 0.12)**2
        
        elif dataset_type == DatasetType.DIFFICULT.value:
            # Difficult dataset: sensitive, sharp drop
            tsr_mean = base_perf - 45 * (lambda_vals - 0.08)**2 * model_sens
            tsr_mean = tsr_mean - 25 * (lambda_vals - 0.5)**4
            tsr_mean = np.clip(tsr_mean, 35, base_perf)
            std_lambda = 3.0 + 2.5 * (lambda_vals - 0.08)**2
        
        elif dataset_type == DatasetType.NOISY.value:
            # Noisy dataset: high variance
            tsr_mean = base_perf - 25 * (lambda_vals - 0.12)**2 * model_sens
            tsr_mean = np.clip(tsr_mean, 50, base_perf)
            std_lambda = 4.0 + 1.5 * lambda_vals
        
        elif dataset_type == DatasetType.SPARSE.value:
            # Sparse dataset: limited resolution
            tsr_mean = base_perf - 30 * (lambda_vals - 0.12)**2 * model_sens
            tsr_mean = np.clip(tsr_mean, 55, base_perf)
            std_lambda = 2.0 + 1.0 * (lambda_vals - 0.12)**2
        
        elif dataset_type == DatasetType.IMBALANCED.value:
            # Imbalanced dataset: uneven performance
            tsr_mean = base_perf - 20 * (lambda_vals - 0.12)**2 * model_sens
            tsr_mean = tsr_mean - 15 * np.sin(lambda_vals * np.pi * 4) * model_sens
            tsr_mean = np.clip(tsr_mean, 60, base_perf)
            std_lambda = 2.5 + 1.0 * lambda_vals
        
        else:  # STANDARD
            tsr_mean = base_perf - 25 * (lambda_vals - 0.12)**2 * model_sens
            tsr_mean = tsr_mean - 15 * (lambda_vals - 0.5)**3
            tsr_mean = np.clip(tsr_mean, 48.7, base_perf + 2)
            std_lambda = 2.0 + 1.5 * (lambda_vals - 0.12)**2
        
        # Apply data quality
        tsr_mean = self._apply_data_quality(tsr_mean)
        
        # Add noise
        noise_level = self.config.model.noise_level
        tsr_mean += np.random.normal(0, noise_level, len(lambda_vals))
        tsr_mean = np.clip(tsr_mean, 0, 100)
        
        return lambda_vals, tsr_mean, std_lambda
    
    def generate_gamma_data(self) -> Tuple[np.ndarray, np.ndarray, np.ndarray]:
        """Generate gamma data with dynamic behavior"""
        
        gamma_min = self.config.hyperparameters.gamma_min
        gamma_max = self.config.hyperparameters.gamma_max
        gamma_points = self.config.hyperparameters.gamma_points
        
        gamma_vals = np.linspace(gamma_min, gamma_max, gamma_points)
        
        perf_mult = self._get_performance_multiplier()
        sens_mult = self._get_sensitivity_multiplier()
        base_perf = self.config.dataset.base_performance * perf_mult
        model_sens = self.config.model.sensitivity_to_gamma * sens_mult
        
        dataset_type = self.config.dataset.name
        task_corr = self.config.dataset.task_correlation
        
        if dataset_type == DatasetType.EASY.value:
            tsr_mean = base_perf - 6 * gamma_vals * model_sens
            tsr_mean = np.clip(tsr_mean, 82, base_perf + 1)
            std_gamma = 1.0 + 0.3 * gamma_vals
        
        elif dataset_type == DatasetType.DIFFICULT.value:
            tsr_mean = base_perf - 40 * gamma_vals * model_sens
            tsr_mean = tsr_mean - 15 * gamma_vals**2
            tsr_mean = np.clip(tsr_mean, 50, base_perf)
            std_gamma = 2.5 + 4.0 * gamma_vals
        
        elif dataset_type == DatasetType.NOISY.value:
            tsr_mean = base_perf - 20 * gamma_vals * model_sens
            tsr_mean = np.clip(tsr_mean, 60, base_perf)
            std_gamma = 3.5 + 2.0 * gamma_vals
        
        else:  # STANDARD
            tsr_mean = base_perf - 15 * gamma_vals * model_sens
            # Adjust for task correlation
            tsr_mean = tsr_mean * (0.7 + 0.3 * task_corr)
            tsr_mean = np.clip(tsr_mean, 72.4, base_perf + 1)
            std_gamma = 1.8 + 2.0 * gamma_vals
        
        # Apply data quality and noise
        tsr_mean = self._apply_data_quality(tsr_mean)
        tsr_mean += np.random.normal(0, self.config.model.noise_level, len(gamma_vals))
        tsr_mean = np.clip(tsr_mean, 0, 100)
        
        return gamma_vals, tsr_mean, std_gamma
    
    def generate_beta_data(self) -> Tuple[np.ndarray, np.ndarray, np.ndarray, np.ndarray, np.ndarray]:
        """Generate beta data with dynamic behavior"""
        
        beta_min = self.config.hyperparameters.beta_min
        beta_max = self.config.hyperparameters.beta_max
        beta_points = self.config.hyperparameters.beta_points
        
        beta_vals = np.linspace(beta_min, beta_max, beta_points)
        
        perf_mult = self._get_performance_multiplier()
        sens_mult = self._get_sensitivity_multiplier()
        base_perf = self.config.dataset.base_performance * perf_mult
        model_sens = self.config.model.sensitivity_to_beta * sens_mult
        
        dataset_type = self.config.dataset.name
        opt_level = self.config.model.optimization_level
        
        # Different performance patterns based on optimization level
        if opt_level == "high":
            # High optimization: more robust proposed method
            tsr_proposed = base_perf - 15 * (beta_vals - 0.28)**2 * model_sens
            tsr_proposed = tsr_proposed + 8 * (beta_vals - 0.28)**4
            tsr_ema = base_perf - 35 * (beta_vals - 0.25)**2 - 250 * (beta_vals - 0.25)**4
        
        elif opt_level == "low":
            # Low optimization: both methods perform poorly
            tsr_proposed = base_perf - 35 * (beta_vals - 0.32)**2 * model_sens
            tsr_proposed = np.clip(tsr_proposed, 65, base_perf - 5)
            tsr_ema = base_perf - 50 * (beta_vals - 0.28)**2 - 400 * (beta_vals - 0.28)**4
        
        else:  # standard
            tsr_proposed = base_perf - 25 * (beta_vals - 0.3)**2 * model_sens
            tsr_proposed = tsr_proposed + 10 * (beta_vals - 0.3)**4
            tsr_ema = base_perf - 40 * (beta_vals - 0.22)**2 - 300 * (beta_vals - 0.22)**4
        
        # Dataset-specific modifications
        if dataset_type == DatasetType.EASY.value:
            tsr_proposed = np.clip(tsr_proposed, 88, base_perf + 2)
            tsr_ema = np.clip(tsr_ema, 80, base_perf)
        
        elif dataset_type == DatasetType.DIFFICULT.value:
            tsr_proposed = np.clip(tsr_proposed, 70, base_perf - 5)
            tsr_ema = np.clip(tsr_ema, 55, base_perf - 10)
        
        # Apply noise and smoothing
        noise_level = self.config.model.noise_level
        tsr_proposed += np.random.normal(0, noise_level, len(beta_vals))
        tsr_ema += np.random.normal(0, noise_level + 0.1, len(beta_vals))
        
        # Smooth data
        window = min(7, beta_points if beta_points % 2 == 1 else beta_points - 1)
        if window >= 3:
            tsr_proposed = savgol_filter(tsr_proposed, window_length=window, polyorder=3)
            tsr_ema = savgol_filter(tsr_ema, window_length=window, polyorder=3)
        
        # Standard deviations
        std_proposed = 1.0 + 0.6 * (beta_vals - 0.3)**2
        std_ema = 1.5 + 1.5 * (beta_vals - 0.3)**2
        
        # Apply data quality
        tsr_proposed = self._apply_data_quality(tsr_proposed)
        tsr_ema = self._apply_data_quality(tsr_ema)
        
        tsr_proposed = np.clip(tsr_proposed, 0, 100)
        tsr_ema = np.clip(tsr_ema, 0, 100)
        
        return beta_vals, tsr_proposed, tsr_ema, std_proposed, std_ema

