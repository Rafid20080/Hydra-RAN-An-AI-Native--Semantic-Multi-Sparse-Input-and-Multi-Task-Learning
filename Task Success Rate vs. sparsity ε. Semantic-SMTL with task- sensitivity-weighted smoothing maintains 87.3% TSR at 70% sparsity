def run_dynamic_simulation(preset: str = "standard",
                          custom_config: Optional[Dict] = None,
                          save_prefix: str = "tsr_vs_sparsity_dynamic"):
    """
    Run dynamic simulation with specified configuration
    
    Parameters:
    -----------
    preset : str
        Preset configuration name
    custom_config : dict, optional
        Custom configuration overrides
    save_prefix : str
        Prefix for saved files
    """
    
    # Get preset configuration
    dataset_config, model_config, sim_config, viz_config = get_preset_config(preset)
    
    # Apply custom overrides
    if custom_config:
        if 'dataset' in custom_config:
            for key, value in custom_config['dataset'].items():
                if hasattr(dataset_config, key):
                    setattr(dataset_config, key, value)
        if 'model' in custom_config:
            for key, value in custom_config['model'].items():
                if hasattr(model_config, key):
                    setattr(model_config, key, value)
        if 'simulation' in custom_config:
            for key, value in custom_config['simulation'].items():
                if hasattr(sim_config, key):
                    setattr(sim_config, key, value)
    
    # Store sim_config in plotter access
    DynamicPlotter.sim_config = sim_config
    
    print("\n" + "=" * 70)
    print(f"DYNAMIC TSR VS SPARSITY SIMULATION")
    print(f"Preset: {preset.upper()}")
    print("=" * 70)
    print(f"Sensing Quality: {dataset_config.sensing_quality}")
    print(f"Environment: {dataset_config.environment}")
    print(f"Model Sophistication: {model_config.sophistication}")
    print(f"SNR Range: {dataset_config.snr_range[0]}-{dataset_config.snr_range[1]} dB")
    print("=" * 70)
    
    # Generate dynamic data
    generator = DynamicPerformanceGenerator(dataset_config, model_config, sim_config)
    data = generator.generate_all_methods_data()
    
    # Create plotter and generate figure
    plotter = DynamicPlotter(viz_config)
    fig = plotter.plot_tsr_vs_sparsity(data, dataset_config, model_config, save_prefix)
    
    # Print summary
    print_summary(data, dataset_config, model_config)
    
    return fig, data

def print_summary(data: Dict, dataset_config: DatasetConfig, model_config: ModelConfig):
    """Print comprehensive summary of results"""
    
    print("\n" + "=" * 70)
    print("DYNAMIC SIMULATION SUMMARY")
    print("=" * 70)
    
    # Find sparsity=0.7 performance
    x = data['x']
    sparsity_70_idx = np.where(x == 0.7)[0]
    
    if len(sparsity_70_idx) > 0:
        idx = sparsity_70_idx[0]
        
        print(f"\nKEY RESULT (ε = 0.7 sparsity):")
