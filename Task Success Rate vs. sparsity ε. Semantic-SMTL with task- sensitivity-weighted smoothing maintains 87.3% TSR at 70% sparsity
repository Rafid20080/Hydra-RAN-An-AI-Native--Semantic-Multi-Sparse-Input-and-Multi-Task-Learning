def get_preset_config(preset_name: str) -> Tuple[DatasetConfig, ModelConfig, SimulationConfig, VisualizationConfig]:
    """Get preset configuration for different scenarios"""
    
    presets = {
        "standard": {
            "dataset": DatasetConfig(sensing_quality="standard", environment="dynamic"),
            "model": ModelConfig(sophistication="standard", use_attention=True, use_memory=True),
            "simulation": SimulationConfig(),
            "visualization": VisualizationConfig()
        },
        
        "ideal": {
            "dataset": DatasetConfig(sensing_quality="ideal", environment="static",
                                    interference_level=0.02, temporal_variation=0.05),
            "model": ModelConfig(sophistication="state_of_art", use_attention=True, 
                                use_memory=True, ensemble_size=3),
            "simulation": SimulationConfig(n_runs=30),
            "visualization": VisualizationConfig()
        },
        
        "challenging": {
            "dataset": DatasetConfig(sensing_quality="degraded", environment="hostile",
                                    interference_level=0.3, temporal_variation=0.4,
                                    snr_range=(0, 15)),
            "model": ModelConfig(sophistication="advanced", use_attention=True,
                                use_memory=True, adaptation_rate=0.2),
            "simulation": SimulationConfig(n_runs=100),
            "visualization": VisualizationConfig()
        },
        
        "urban": {
            "dataset": DatasetConfig(sensing_quality="realistic", environment="urban",
                                    interference_level=0.15, mobility_speed=50,
                                    multipath_components=12, temporal_variation=0.25),
            "model": ModelConfig(sophistication="advanced", use_attention=True,
                                use_memory=True, regularization_strength=0.02),
            "simulation": SimulationConfig(n_runs=75),
            "visualization": VisualizationConfig(color_scheme="tvtd")
        },
        
        "remote": {
            "dataset": DatasetConfig(sensing_quality="noisy", environment="remote",
                                    interference_level=0.05, snr_range=(-5, 10),
                                    temporal_variation=0.15),
            "model": ModelConfig(sophistication="standard", use_attention=True,
                                use_memory=False, ensemble_size=2),
            "simulation": SimulationConfig(n_runs=80),
            "visualization": VisualizationConfig(color_scheme="colorblind")
        }
    }
    
    return presets.get(preset_name, presets["standard"])

