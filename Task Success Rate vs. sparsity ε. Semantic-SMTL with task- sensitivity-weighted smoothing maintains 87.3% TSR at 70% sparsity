class DynamicPerformanceGenerator:
    """
    Generates performance data dynamically based on configuration
    Results change based on dataset and model parameters
    """
    
    def __init__(self, dataset_config: DatasetConfig, model_config: ModelConfig,
                 sim_config: SimulationConfig):
        self.dataset_config = dataset_config
        self.model_config = model_config
        self.sim_config = sim_config
        np.random.seed(sim_config.seed)
        
    def _get_environment_factor(self) -> float:
        """Calculate environment difficulty factor"""
        factors = {
            "static": 0.8,
            "dynamic": 1.0,
            "hostile": 1.4,
            "urban": 1.2,
            "remote": 1.3
        }
        base = factors.get(self.dataset_config.environment, 1.0)
        
        # Adjust for interference
        interference_adjust = 1 + self.dataset_config.interference_level * 0.5
        
        # Adjust for mobility
        mobility_adjust = 1 + self.dataset_config.mobility_speed / 200
        
        return base * interference_adjust * mobility_adjust
    
    def _get_sensing_quality_factor(self) -> float:
        """Calculate sensing quality impact"""
        quality_factors = {
            "ideal": 1.2,
            "standard": 1.0,
            "degraded": 0.85,
            "noisy": 0.75,
            "realistic": 0.9
        }
        base = quality_factors.get(self.dataset_config.sensing_quality, 1.0)
        
        # Adjust for SNR
        avg_snr = np.mean(self.dataset_config.snr_range)
        snr_factor = 1 - max(0, (20 - avg_snr) / 100)
        
        return base * snr_factor
    
    def _get_model_capability_factor(self) -> float:
        """Calculate model capability multiplier"""
        sophistication_factors = {
            "basic": 0.7,
            "standard": 1.0,
            "advanced": 1.15,
            "state_of_art": 1.25
        }
        base = sophistication_factors.get(self.model_config.sophistication, 1.0)
        
        # Adjust for model features
        if self.model_config.use_attention:
            base *= 1.08
        if self.model_config.use_memory:
            base *= 1.05
        if self.model_config.ensemble_size > 1:
            base *= (1 + 0.02 * min(self.model_config.ensemble_size, 5))
        
        return base
    
    def _calculate_base_performance(self, sparsity: float, method: str) -> float:
        """Calculate base performance for a given method at specific sparsity"""
        
        # Base formulas for different methods
        method_formulas = {
            "task_sensitive": lambda s: 0.95 - 0.17 * s - 0.1 * s**2,
            "standard_ema": lambda s: 0.93 - 0.38 * s - 0.1 * s**2,
            "jcas": lambda s: max(0.82 * (1 - s) - 0.03, 0.05),
            "sran": lambda s: max(0.88 * (1 - 0.8 * s) - 0.08, 0.05),
            "graph": lambda s: max(0.78 * (1 - 1.2 * s) - 0.05, 0.05),
            "drl": lambda s: max(0.75 * (1 - 1.5 * s) - 0.08, 0.05)
        }
        
        base_perf = method_formulas.get(method, method_formulas["standard_ema"])(sparsity)
        
        # Apply environment and sensing quality factors
        env_factor = self._get_environment_factor()
        sensing_factor = self._get_sensing_quality_factor()
        
        # Different methods have different sensitivity to environment
        sensitivity = {
            "task_sensitive": 0.5,
            "standard_ema": 0.7,
            "jcas": 0.8,
            "sran": 0.75,
            "graph": 0.7,
            "drl": 0.9
        }
        
        method_sensitivity = sensitivity.get(method, 0.7)
        adjusted_perf = base_perf * (1 - (1 - sensing_factor) * method_sensitivity)
        adjusted_perf = adjusted_perf * (1 - (env_factor - 1) * method_sensitivity * 0.3)
        
        # Apply model capability for task_sensitive method
        if method == "task_sensitive":
            model_factor = self._get_model_capability_factor()
            adjusted_perf = min(adjusted_perf * model_factor, 0.98)
        
        # Add temporal variation
        temporal_variation = self.dataset_config.temporal_variation
        if temporal_variation > 0:
            variation = np.random.normal(1, temporal_variation * 0.05)
            adjusted_perf *= variation
        
        return np.clip(adjusted_perf, 0.05, 0.98)
    
    def generate_performance_curve(self, method: str, with_std: bool = True) -> Tuple[np.ndarray, Optional[np.ndarray]]:
        """Generate performance curve for a specific method"""
        
        sparsity_levels = np.array(self.sim_config.sparsity_levels)
        n_points = len(sparsity_levels)
        
        # Generate mean performance
        mean_performance = np.array([self._calculate_base_performance(s, method) for s in sparsity_levels])
        
        # Add random noise based on configuration
        noise_level = 0.01 * (1 + self.dataset_config.interference_level)
        if self.dataset_config.sensing_quality == "noisy":
            noise_level *= 2
        
        mean_performance += np.random.normal(0, noise_level, n_points)
        mean_performance = np.clip(mean_performance, 0.05, 0.98)
        
        # Smooth the curve
        if n_points > 5:
            from scipy.signal import savgol_filter
            window = min(5, n_points if n_points % 2 == 1 else n_points - 1)
            if window >= 3:
                mean_performance = savgol_filter(mean_performance, window, 2)
        
        # Calculate standard deviation
        if with_std:
            std_base = 0.01 + 0.02 * np.sqrt(sparsity_levels)
            std_performance = std_base * (1 + self.dataset_config.interference_level)
            std_performance = std_performance * (1 + self.dataset_config.temporal_variation * 0.5)
            return mean_performance, std_performance
        
        return mean_performance, None
    
    def generate_all_methods_data(self) -> Dict:
        """Generate performance data for all methods"""
        
        methods = ["task_sensitive", "standard_ema"]
        if self.sim_config.include_baselines:
            methods.extend(self.sim_config.baseline_methods)
        
        data = {'x': np.array(self.sim_config.sparsity_levels)}
        
        for method in methods:
            mean, std = self.generate_performance_curve(method, True)
            data[method] = {
                'mean': mean,
                'std': std if self.sim_config.confidence_interval > 0 else None
            }
        
        return data

