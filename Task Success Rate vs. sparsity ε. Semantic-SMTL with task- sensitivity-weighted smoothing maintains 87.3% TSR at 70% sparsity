class DynamicPlotter:
    """Dynamic plotter with configurable styling"""
    
    def __init__(self, viz_config: VisualizationConfig):
        self.config = viz_config
        self._setup_plot_style()
    
    def _setup_plot_style(self):
        """Setup matplotlib style based on configuration"""
        plt.rcParams.update({
            "font.family": "Times New Roman",
            "mathtext.fontset": "stix",
            "font.size": 13,
            "axes.labelsize": 14,
            "axes.titlesize": 13,
            "xtick.labelsize": 12,
            "ytick.labelsize": 12,
            "legend.fontsize": 11,
            "figure.dpi": self.config.dpi,
            "savefig.dpi": self.config.dpi,
            "lines.linewidth": 2.8,
            "lines.markersize": 8,
            "axes.linewidth": 1.3,
            "axes.grid": True,
            "grid.alpha": 0.25,
            "grid.linestyle": "--",
            "xtick.direction": "in",
            "ytick.direction": "in",
            "xtick.top": True,
            "ytick.right": True,
            "xtick.major.width": 1.3,
            "ytick.major.width": 1.3,
            "xtick.major.size": 6,
            "ytick.major.size": 6,
            "xtick.minor.size": 3.5,
            "ytick.minor.size": 3.5,
            "legend.frameon": True,
            "legend.fancybox": False,
            "legend.edgecolor": "black",
            "legend.framealpha": 0.95,
            "pdf.fonttype": 42,
            "ps.fonttype": 42
        })
    
    def _get_color_scheme(self) -> Dict:
        """Get color scheme based on configuration"""
        if self.config.color_scheme == "tvtd":
            return {
                'task_sensitive': '#1f77b4',  # Blue
                'standard_ema': '#2ca02c',    # Green
                'jcas': '#d62728',            # Red
                'sran': '#ff7f0e',            # Orange
                'graph': '#9467bd',           # Purple
                'drl': '#8c564b'              # Brown
            }
        elif self.config.color_scheme == "colorblind":
            return {
                'task_sensitive': '#0072B2',
                'standard_ema': '#009E73',
                'jcas': '#D55E00',
                'sran': '#E69F00',
                'graph': '#CC79A7',
                'drl': '#F0E442'
            }
        else:  # grayscale
            grays = ['#202020', '#404040', '#606060', '#808080', '#A0A0A0', '#C0C0C0']
            methods = ['task_sensitive', 'standard_ema', 'jcas', 'sran', 'graph', 'drl']
            return {method: grays[i] for i, method in enumerate(methods)}
    
    def _get_marker_style(self, method: str) -> str:
        """Get marker style for method"""
        markers = {
            'task_sensitive': 'o',
            'standard_ema': 's',
            'jcas': '^',
            'sran': 'v',
            'graph': 'd',
            'drl': 'x'
        }
        return markers.get(method, 'o')
    
    def _get_line_style(self, method: str) -> str:
        """Get line style for method"""
        styles = {
            'task_sensitive': '-',
            'standard_ema': '-.',
            'jcas': '--',
            'sran': '--',
            'graph': '-',
            'drl': '--'
        }
        return styles.get(method, '-')
    
    def plot_tsr_vs_sparsity(self, data: Dict, dataset_config: DatasetConfig,
                            model_config: ModelConfig, save_prefix: str = 'tsr_vs_sparsity') -> plt.Figure:
        """Generate dynamic publication-quality figure"""
        
        x = data['x']
        
        # Create figure
        fig = plt.figure(figsize=(self.config.fig_width, self.config.fig_height))
        ax = plt.gca()
        
        # Subplot adjustment
        plt.subplots_adjust(top=0.68, bottom=0.12, left=0.12, right=0.95)
        
        # Get styling
        colors = self._get_color_scheme()
        
        # Methods to plot
        methods = ['task_sensitive', 'standard_ema']
        if self.sim_config.include_baselines:
            methods.extend(self.sim_config.baseline_methods)
        
        # Labels for methods
        labels = {
            'task_sensitive': 'Semantic-SMTL (Task-Sens.-Weighted)',
            'standard_ema': 'Semantic-SMTL (Std. EMA)',
            'jcas': 'JCAS',
            'sran': 'S-RAN',
            'graph': 'Graph-RAN',
            'drl': 'DRL-Only'
        }
        
        # Plot each method
        for method in methods:
            if method not in data:
                continue
                
            mean = data[method]['mean']
            std = data[method]['std']
            
            # Calculate confidence interval
            if self.config.show_confidence_bands and std is not None:
                n = self.sim_config.n_runs
                ci = stats.t.ppf((1 + self.sim_config.confidence_interval) / 2, n - 1) * std / np.sqrt(n)
            
            # Main line
            ax.plot(x, mean, 
                   marker=self._get_marker_style(method),
                   markevery=1,
                   markersize=8,
                   linewidth=2.8,
                   color=colors.get(method, '#000000'),
                   linestyle=self._get_line_style(method),
                   label=labels.get(method, method),
                   markerfacecolor='white',
                   markeredgewidth=1.5,
                   markeredgecolor=colors.get(method, '#000000'),
                   zorder=3)
            
            # Confidence interval shading
            if self.config.show_confidence_bands and std is not None:
                ax.fill_between(x, mean - ci, mean + ci,
                               color=colors.get(method, '#000000'),
                               alpha=0.12, linewidth=0, zorder=1)
        
        # Find sparsity=0.7 performance
        sparsity_70_idx = np.where(x == 0.7)[0]
        if len(sparsity_70_idx) > 0:
            idx = sparsity_70_idx[0]
            ts_perf = data['task_sensitive']['mean'][idx]
            ema_perf = data['standard_ema']['mean'][idx]
            gain = ((ts_perf - ema_perf) / ema_perf) * 100 if ema_perf > 0 else 0
            
            # Add reference lines
            if self.config.show_annotations:
                ax.axhline(y=ts_perf, linestyle=':', linewidth=2.0, color='gray', alpha=0.7, dashes=(4, 4))
                ax.axvline(x=0.7, linestyle=':', linewidth=2.0, color='gray', alpha=0.7, dashes=(4, 4))
                
                # Add annotation
                ax.annotate(f'{ts_perf*100:.1f}% at ε = 0.7\n(+{gain:.0f}% vs. Std. EMA)',
                           xy=(0.7, ts_perf),
                           xytext=(0.48, min(ts_perf + 0.1, 0.98)),
                           arrowprops=dict(arrowstyle='->', color='black', lw=1.5,
                                         connectionstyle='arc3,rad=0.1'),
                           fontsize=11, fontweight='bold',
                           bbox=dict(boxstyle='round,pad=0.4', facecolor='white',
                                    edgecolor='black', alpha=0.95, linewidth=1.0))
        
        # Labels
        ax.set_xlabel('Sparsity $\\varepsilon$', labelpad=10, fontsize=14, fontweight='bold')
        ax.set_ylabel('Task Success Rate (TSR)', labelpad=10, fontsize=14, fontweight='bold')
        
        # Axes limits
        ax.set_xlim(-0.02, 0.92)
        ax.set_ylim(0, 1.08)
        
        # Tick formatting
        ax.set_xticks(np.arange(0, 1.01, 0.2))
        ax.set_yticks(np.arange(0, 1.01, 0.2))
        ax.set_xticklabels([f'{tick:.1f}' for tick in np.arange(0, 1.01, 0.2)])
        ax.set_yticklabels([f'{tick:.1f}' for tick in np.arange(0, 1.01, 0.2)])
        
        # Minor ticks
        ax.set_xticks(np.arange(0, 1.0, 0.1), minor=True)
        ax.set_yticks(np.arange(0, 1.0, 0.1), minor=True)
        ax.tick_params(axis='both', which='major', length=6, width=1.3)
        ax.tick_params(axis='both', which='minor', length=3.5, width=0.8)
        
        # Grid
        ax.grid(which='major', linestyle='--', alpha=0.3, linewidth=0.9)
        ax.grid(which='minor', linestyle=':', alpha=0.15, linewidth=0.6)
        ax.set_axisbelow(True)
        
        # Legend
        fig_height_inches = fig.get_size_inches()[1]
        spacing_cm = 1.0
        spacing_inches = spacing_cm / 2.54
        legend_bottom_figure = 0.832 - (spacing_inches / fig_height_inches)
        legend_height_figure = 0.12
        legend_center_y = legend_bottom_figure + (legend_height_figure / 2)
        
        legend = ax.legend(
            loc='upper center',
            bbox_to_anchor=(0.5, legend_center_y),
            bbox_transform=fig.transFigure,
            ncol=3,
            framealpha=0.96,
            borderpad=0.6,
            handlelength=3.0,
            handletextpad=0.8,
            columnspacing=1.0,
            edgecolor='black',
            fancybox=False
        )
        
        for text in legend.get_texts():
            text.set_fontweight('bold')
            text.set_fontsize(11)
        
        legend.get_frame().set_linewidth(1.2)
        
        # Spines
        for spine in ax.spines.values():
            spine.set_linewidth(1.3)
        
        # Information box with dynamic content
        info_box_props = dict(
            boxstyle='round,pad=0.35',
            facecolor='#f8f8f8',
            edgecolor='gray',
            alpha=0.9,
            linewidth=0.8
        )
        
        info_text = (f"Configuration:\n"
                    f"• Sensing: {dataset_config.sensing_quality}\n"
                    f"• Environment: {dataset_config.environment}\n"
                    f"• Model: {model_config.sophistication}\n"
                    f"• SNR: {np.mean(dataset_config.snr_range):.0f} dB")
        
        ax.text(0.02, 0.02, info_text, transform=ax.transAxes, fontsize=9,
                verticalalignment='bottom', bbox=info_box_props,
                fontweight='medium')
        
        plt.tight_layout()
        
        # Save figures
        for fmt in self.config.save_formats:
            filename = f'{save_prefix}.{fmt}'
            dpi = self.config.dpi if fmt != 'pdf' else 600
            plt.savefig(filename, format=fmt, dpi=dpi, bbox_inches='tight')
            print(f"  Saved: {filename}")
        
        plt.show()
        
        return fig

